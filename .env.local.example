# Copy to .env.local and fill from your Supabase project (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: identify your app for OpenStreetMap Nominatim (map geocoding).
# NOMINATIM_USER_AGENT=Aervara/1.0 (https://yoursite.com; contact@you.com)
