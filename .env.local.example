# Copy to .env.local and fill from your Supabase project (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: identify your app for OpenStreetMap Nominatim (map geocoding).
# NOMINATIM_USER_AGENT=Aervara/1.0 (https://yoursite.com; contact@you.com)

# Optional: Socrata app token for Cook County / City of Chicago open data (higher rate limits; not required).
# SOCRATA_APP_TOKEN=

# Optional: reserved for future Chicago Cityscape / premium zoning integrations (unused in this build).
# CHICAGO_CITYSCAPE_API_KEY=

# Optional: grant Aervara Pro without Stripe (testing). Comma-separated lists.
# AERVARA_PRO_USER_IDS=uuid-from-supabase-auth-users,another-uuid
# AERVARA_PRO_EMAILS=you@company.com,coworker@company.com

# Optional: exclusivity admin override (bypass invite approval checks).
# AERVARA_ADMIN_OVERRIDE_USER_IDS=uuid-from-supabase-auth-users
# AERVARA_ADMIN_OVERRIDE_EMAILS=you@company.com

# --- Stripe (server only; never expose secret keys to the client) ---
# Required for Checkout + Customer Portal API routes:
# STRIPE_SECRET_KEY=sk_test_...   # or sk_live_... in production
# Required recurring Price IDs (Dashboard → Products → your product → copy Price ID):
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_ELITE_MONTHLY=price_...
# Required for POST /api/stripe/webhook (Stripe CLI forward or Dashboard webhook):
# STRIPE_WEBHOOK_SECRET=whsec_...
# Recommended when Origin is missing (e.g. cron); also used as fallback for success/cancel URLs:
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for webhooks to upsert billing fields on user_profiles (server only):
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional: seed curated demo properties (INSERT only for one user; never deletes data).
# SEED_TARGET_USER_ID=paste-auth-user-uuid
# Then: npm run seed:examples
# Inserts urban development demo rows (marker: aervara-seed-urban-dev-opportunities-v1 in notes).
